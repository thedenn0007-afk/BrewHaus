{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/menu", "destination": "/pages/menu.html" },
    { "source": "/gallery", "destination": "/pages/gallery.html" },
    { "source": "/offers", "destination": "/pages/offers.html" },
    { "source": "/contact", "destination": "/pages/contact.html" },
    { "source": "/builder", "destination": "/pages/builder.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
